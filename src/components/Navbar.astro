---
export const prerender = false;

const accessToken = Astro.cookies.get("SB_ACCESS_TOKEN")?.value;
const userName = Astro.cookies.get("SB_USER_NAME")?.value;
const isSignedIn = Boolean(accessToken);
---

<nav class="nav" role="navigation" aria-label="Main navigation">
	<div class="container">
		<a class="brand" href="/">Healthy Diet</a>
		<div class="nav-actions">
			<ul class="links">
				<li><a href="#meals">Meals</a></li>
				<li><a href="#activities">Activities</a></li>
				<li><a href="#tips">Tips</a></li>
				<li><a href="#faq">FAQ</a></li>
			</ul>
			{isSignedIn ? (
				<div class="auth-actions">
					<span class="user-pill">Hi, {userName ?? "there"}</span>
					<form method="post" action="/api/auth/signout" class="signout-form">
						<button type="submit" class="signout-btn">Sign out</button>
					</form>
				</div>
			) : (
				<a href="/signin" class="signin-link">Sign in</a>
			)}
		</div>
	</div>
</nav>

<style>
	.nav{position:fixed;top:0;left:0;right:0;background:rgba(255,255,255,0.9);backdrop-filter:blur(6px);box-shadow:0 2px 8px rgba(0,0,0,0.04);z-index:50}
	.nav .container{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:12px 16px;gap:16px}
	.brand{font-weight:700;color:var(--primary);text-decoration:none}
	.nav-actions{display:flex;align-items:center;gap:12px}
	.links{display:flex;gap:12px;list-style:none;padding:0;margin:0}
	.links a,.signin-link{text-decoration:none;color:var(--text)}
	.auth-actions{display:flex;align-items:center;gap:10px}
	.user-pill{padding:6px 10px;border-radius:999px;background:rgba(251,113,133,0.12);color:var(--primary);font-weight:600}
	.signout-form{display:flex}
	.signout-btn,.signin-link{border:1px solid rgba(251,113,133,0.2);background:white;border-radius:999px;padding:7px 12px;color:var(--primary);font-weight:600;cursor:pointer;text-decoration:none}
	.signout-btn:hover,.signin-link:hover{background:rgba(251,113,133,0.08)}
	@media(max-width:600px){.links{display:none}.nav-actions{gap:8px}.user-pill{display:none}}
</style>
