---
import { activities } from '../data/activities';
---

<section id="activities" aria-labelledby="activities-title">
	<h2 id="activities-title">Daily Activities</h2>
	<ul class="activities">
		{activities.map(a => (
			<li>
				<label>
					<input type="checkbox" aria-label={`Mark ${a.title} done`} />
					<span class="title">{a.title}</span>
					<p class="desc">{a.description}</p>
				</label>
			</li>
		))}
	</ul>
</section>

<style>
	#activities{max-width:900px;margin:24px auto;padding:0 16px}
	.activities{list-style:none;padding:0;margin:0;display:grid;gap:8px}
	.activities li{background:white;padding:10px;border-radius:10px;box-shadow:0 6px 12px rgba(0,0,0,0.04)}
	.activities label{display:flex;align-items:center;gap:12px}
	.activities .title{font-weight:600}
	.activities .desc{margin:4px 0 0;color:#6b7280;font-size:14px}
</style>
