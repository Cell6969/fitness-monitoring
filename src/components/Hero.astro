---
const isSignedIn = Boolean(Astro.cookies.get("SB_ACCESS_TOKEN")?.value);
const trackerHref = isSignedIn ? "/weight-tracker" : "/signin?redirect=/weight-tracker";
---

<section id="hero" aria-labelledby="hero-title">
	<div class="inner">
		<h1 id="hero-title">Healthy Diet Guide</h1>
		<p>Simple daily meal recommendations and healthy activities.</p>
		<div class="cta-group">
			<a class="cta" href="#meals">View Today's Menu</a>
			<a class="cta secondary" href={trackerHref}>Track Weight</a>
		</div>
	</div>
</section>

<style>
	#hero .inner{
		max-width: 900px;
		margin: 48px auto;
		text-align: center;
		padding: 24px;
		background: rgba(255,255,255,0.9);
		border-radius: 12px;
		box-shadow: 0 6px 18px rgba(0,0,0,0.08);
	}
	#hero h1{margin:0 0 8px;font-size:28px;color:#b91c1c}
	#hero p{margin:0 0 16px;color:#7f1d1d}
	.cta-group{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
	#hero .cta{display:inline-block;padding:10px 16px;border-radius:10px;background:#fb7185;color:white;text-decoration:none;font-weight:600}
	#hero .cta.secondary{background:white;color:#be123c;border:1px solid rgba(190,18,60,0.2)}
</style>
