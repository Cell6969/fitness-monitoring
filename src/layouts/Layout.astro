---
import background from '../assets/background.svg';
import panda from '../assets/panda.png';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Program Diet</title>
	</head>
	<body>
		<img id="background" src={background.src} alt="" fetchpriority="high" />
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
		<img class="panda" src={panda.src} alt="Panda mascot" />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
		background-color: var(--bg);
		color: var(--text);
	}

	main{min-height:calc(100vh - 160px);padding-top:72px}

	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(20px);
	}
	.panda{position:fixed;right:0px;bottom:12px;width:350px;height:auto;z-index:60;pointer-events:none}
</style>
